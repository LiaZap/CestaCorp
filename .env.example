# === App ===
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# === Postgres (Prisma) ===
DATABASE_URL=postgresql://cestacorp:cestacorp@postgres:5432/cestacorp?schema=public

# === MongoDB (Mongoose) ===
MONGODB_URI=mongodb://mongo:27017/cestacorp

# === NIBO ===
NIBO_API_URL=https://api.nibo.com.br/empresas/v1
NIBO_TOKEN=replace-with-your-token

# === DIGISAC / HUBLX ===
DIGISAC_API_URL=https://cestacorp.hublx.app/api/v1
DIGISAC_TOKEN=replace-with-your-token
DIGISAC_SERVICE_ID=

# === SMTP (canal E-MAIL da régua) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@cestacorp.com.br

# === Autentique (assinatura digital) ===
# Cadastre-se em https://www.autentique.com.br e gere o token em Configurações → API
# AUTENTIQUE_SANDBOX=true usa o ambiente de testes (não consome créditos)
AUTENTIQUE_TOKEN=
AUTENTIQUE_SANDBOX=false
AUTENTIQUE_WEBHOOK_SECRET=

# === Timezone / Cron ===
TZ=America/Sao_Paulo
CRON_REGUA_ENABLED=true
