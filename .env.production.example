# ====================================================
# Cestacorp — Template para EasyPanel (produção)
# Copie como .env.production e preencha os valores REAIS
# NUNCA commite o .env.production preenchido.
# ====================================================

# === App ===
NODE_ENV=production
NEXTAUTH_URL=https://cestacorp.seudominio.com.br
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=GERAR-COM-OPENSSL-RAND-BASE64-32
TZ=America/Sao_Paulo

# === Postgres (Prisma) ===
# No EasyPanel, crie um serviço "Postgres" e aponte aqui.
# Dentro da rede interna: postgres:5432 (porta padrão)
POSTGRES_USER=cestacorp
POSTGRES_PASSWORD=SENHA-FORTE-AQUI
POSTGRES_DB=cestacorp
DATABASE_URL=postgresql://cestacorp:SENHA-FORTE-AQUI@postgres:5432/cestacorp?schema=public

# === MongoDB (Mongoose) - só para formulários dinâmicos ===
MONGODB_URI=mongodb://mongo:27017/cestacorp

# === NIBO (financeiro) ===
NIBO_API_URL=https://api.nibo.com.br/empresas/v1
NIBO_TOKEN=<gere-em-https://app.nibo.com.br/integracoes/api>
NIBO_WEBHOOK_SECRET=GERAR-COM-OPENSSL-RAND-HEX-32

# === DIGISAC / HUBLX (WhatsApp) ===
DIGISAC_API_URL=https://cestacorp.hublx.app/api/v1
DIGISAC_TOKEN=<gere-no-painel-digisac>
DIGISAC_SERVICE_ID=
DIGISAC_WEBHOOK_SECRET=GERAR-COM-OPENSSL-RAND-HEX-32

# === SMTP (e-mail de reset, notificações) ===
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@cestacorp.com.br
SMTP_PASSWORD=SENHA-DO-SMTP
SMTP_FROM="Cestacorp <no-reply@cestacorp.com.br>"

# === Autentique (assinatura digital — preferida) ===
# https://www.autentique.com.br → Configurações → API
AUTENTIQUE_TOKEN=
AUTENTIQUE_SANDBOX=false
AUTENTIQUE_WEBHOOK_SECRET=

# === ClickSign (assinatura digital — fallback opcional) ===
# Se em branco e Autentique também, fica em modo mock
CLICKSIGN_TOKEN=

# === Anthropic Claude (OCR de documentos) ===
# Se em branco, OCR fica em modo mock
ANTHROPIC_API_KEY=

# === S3 compatível (uploads) ===
# Pode usar MinIO, Wasabi, Backblaze, R2, etc.
# Se em branco, uploads salvam em disco local (não-escalável)
S3_ENDPOINT=https://s3.seu-provedor.com
S3_BUCKET=cestacorp-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Cron / Rotinas agendadas ===
CRON_REGUA_ENABLED=true
