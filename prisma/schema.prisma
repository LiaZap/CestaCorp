  parceiroId String
  mes        String // "YYYY-MM"
  valor      Decimal        @db.Decimal(14, 2)
  status     StatusComissao @default(PENDENTE)
  pagoEm     DateTime?
  observacao String?
  parceiro   Parceiro       @relation(fields: [parceiroId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([parceiroId, mes])
  @@map("comissoes_parceiro")
}

enum StatusComissao {
  PENDENTE
  PAGO
  CANCELADO
}

/// Snapshot do reajuste aplicado em cada ano (V-106 CLIENTES colunas 2019-2027).
