  clienteId          String
  contratoId         String?
  ano                Int
  valorAnoBase       Decimal   @db.Decimal(14, 2)
  valorAposReajuste  Decimal   @db.Decimal(14, 2)
  percentualReajuste Decimal   @db.Decimal(8, 4)
  indiceUsado        String // "IPCA", "IGPM", "FIXO 5%"
  motivo             String?
  observacao         String?   @db.Text
  aplicadoEm         DateTime
  aplicadoPor        String?
  niboSincronizado   Boolean   @default(false)
  niboErro           String?   @db.Text
  cliente            Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato           Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  @@unique([clienteId, ano])
  @@index([clienteId])
