// =========================
// PORTAL DO CLIENTE
// =========================
/// Log de auditoria — quem fez o quê, quando
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorType  String // "equipe" | "cliente" | "system"
  actorEmail String?
  action     String // "cliente.update", "reajuste.aplicar", "execucao.reenviar"...
  resource   String // "cliente" | "contrato" | "execucao_regua" | ...
  resourceId String?
  before     Json?
  after      Json?
