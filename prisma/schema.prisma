// =========================
// AGENDA / OBRIGAÇÕES FISCAIS
// =========================
// Obrigacao = modelo/recorrência (ex.: DAS mensal, DEFIS anual)
// Evento = instância calculada em uma data específica (ex.: "DAS de 04/2026")
model Obrigacao {
  id                 String         @id @default(cuid())
  nome               String
  tipo               TipoObrigacao
  descricao          String?        @db.Text
  recorrencia        Recorrencia    @default(MENSAL)
  diaVencimento      Int? // para MENSAL (dia do mês)
  mesVencimento      Int? // para ANUAL (1..12)
  diaVencimentoAnual Int? // para ANUAL (dia dentro do mês)
  dataUnica          DateTime? // para UNICA
  antecedenciaDias   Int            @default(7) // gera notificação X dias antes
  global             Boolean        @default(true) // se true, aplica a todos os clientes ativos
  clienteId          String? // se não-global, amarra a um cliente
  categoriaCliente   Classificacao? // opcional: só aplica a Bronze/Ouro/etc
  tributacaoFiltro   String? // opcional: só se tributação contém texto (ex.: "Simples")
  /// Tags requeridas — só notifica clientes que tenham TODAS estas tags (por slug).
  /// Ex: ["simples-nacional", "folha-com-funcionario"]
  tagsRequeridas     String[]       @default([])
  /// Tags excluídas — pula se o cliente tiver QUALQUER uma delas.
  tagsExcluidas      String[]       @default([])
  responsavel        String?
  /// Setor responsável (V-106 OBRIGAÇÕES): FOLHA, FISCAL, CONTABIL, SOCIETARIO, GERAL.
  setor              String?
  ativa              Boolean        @default(true)
  eventos            EventoAgenda[]
  cliente            Cliente?       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([ativa, recorrencia])
  @@map("obrigacoes")
}

enum TipoObrigacao {
  DAS
  DEFIS
  DIRF
  IRPF
  ECF
  ECD
  FGTS
  ESOCIAL
  DCTF
  SPED_FISCAL
  SPED_CONTRIBUICOES
  REAJUSTE
  REUNIAO
  CERTIFICADO_DIGITAL
  OUTROS
}

enum Recorrencia {
  MENSAL
  ANUAL
  TRIMESTRAL
  SEMESTRAL
  UNICA
}

model EventoAgenda {
  id             String          @id @default(cuid())
  obrigacaoId    String?
  clienteId      String?
  agendaId       String? // FK opcional pra AgendaCalendar (Comercial/Contábil/Financeiro)
  titulo         String
  descricao      String?         @db.Text
  dataVencimento DateTime
  status         StatusEvento    @default(PENDENTE)
  concluidoEm    DateTime?
  concluidoPor   String?
  responsavel    String?
  observacao     String?         @db.Text
  obrigacao      Obrigacao?      @relation(fields: [obrigacaoId], references: [id], onDelete: SetNull)
  cliente        Cliente?        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agenda         AgendaCalendar? @relation(fields: [agendaId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  deletedAt DateTime?

  @@unique([obrigacaoId, clienteId, dataVencimento])
  @@index([dataVencimento, status])
  @@index([deletedAt])
  @@map("eventos_agenda")
}

enum StatusEvento {
  PENDENTE
  CONCLUIDO
  ATRASADO
  ISENTO
  CANCELADO
}

// =========================
// WEBHOOK DEDUP (idempotência)
// =========================
/// Registra eventos de webhook recebidos pra prevenir replay.
/// Auditoria seg #5: sem isso, atacante reenvia evento NIBO de pagamento
/// e marca cobrança como paga duas vezes (dispara notificação dupla, etc).
/// Unique constraint (provider, eventId) bloqueia a 2ª inserção.
/// Recomendado: cron `expurgo` apaga registros > 30 dias.
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String // "nibo", "digisac", "autentique"
  eventId     String
  eventType   String? // "payment.received", "message.received", "document.signed", etc.
  payloadHash String? // sha256 do payload, opcional pra correlação
  processedAt DateTime @default(now())

  @@unique([provider, eventId])
  @@index([processedAt])
  @@map("webhook_events")
}

// =========================
// FILE METADATA (ownership pra storage)
// =========================
/// Registra dono + escopo de cada arquivo do storage (uploads/).
/// Auditoria seg #1: sem isso, /api/files/<hash> aceitava qualquer cliente
/// logado baixar qualquer arquivo conhecendo o SHA256.
/// hash é a chave (mesma usada como nome no FS / key no S3).
/// scope = "cliente" / "contrato" / "nota_fiscal" / "form_response" / "system"
///   - system: assets compartilhados (ex.: templates, logos)
///   - outros: ownerType + ownerId identificam o dono
model FileMetadata {
  hash         String   @id // sha256 do conteúdo
  ext          String // ".pdf", ".docx", etc.
  mime         String
  nomeOriginal String?
  tamanho      Int
  scope        String // "cliente", "contrato", "nota_fiscal", "form_response", "system"
  ownerType    String? // "cliente", "user", "system"
  ownerId      String? // id do dono (clienteId, userId, ou null se system)
  uploadedAt   DateTime @default(now())
  uploadedBy   String? // userId que fez o upload

  @@index([ownerType, ownerId])
  @@index([scope])
  @@map("file_metadata")
}

// =========================================================================
// V-106 ESTENDIDO — Sprint produção (jun/2026)
// 15 models cobrindo abas da V-106 que ainda não estavam representadas:
//   - CertificadoDigital, ProcuracaoEcac, AcessoDecweb (aba CERTIFICADOS)
//   - ClienteResponsavel (aba RESPONSÁVEIS, 87 cols)
//   - Indicacao, Parceiro, ComissaoParceiro (abas CLIENTE/PARCEIRO/EQUIPE INDICA)
//   - ReajusteHistorico (linha do tempo 2019-2027)
//   - AgendaCalendar (aba AGENDAS — 3 calendários)
//   - ObjetoSocial (aba OBJETO SOCIAL — gerador de contrato)
//   - TagAgendamento (cronograma TEXTOS TAGS HUBLX)
//   - AtividadeCatalogo (aba ATIVIDADES — catálogo interno)
//   - TabelaHonorario (aba TABELA HONORARIOS — precificação)
//   - CatalogoServico (aba ÍNDICE — padroniza serviços)
//   - FormFileUpload (Google Drive integration)
// =========================================================================

/// Certificado digital A1/A3 do cliente. Inclui senha CRIPTOGRAFADA (AES-256-GCM
/// com chave derivada de CERTIFICATE_ENCRYPTION_KEY via scrypt). Acesso restrito.
model CertificadoDigital {
  id                   String    @id @default(cuid())
  clienteId            String
  certificadora        String? // "VALID", "SERASA", "AC SOLUTI", etc.
  serial               String?
  validade             DateTime?
  proximaRenov         DateTime?
  senha                String? // AES-256-GCM, ou plaintext em dev se ENV ausente (warn)
  arquivoPath          String? // /api/files/<hash>.pfx
  notificarAntes       Int       @default(30)
  notificarResponsavel String?
  observacao           String?
  cliente              Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([clienteId, validade])
  @@map("certificados_digitais")
}

/// Procuração e-CAC do cliente.
model ProcuracaoEcac {
  id             String    @id @default(cuid())
  clienteId      String
  procuradorCpf  String
  procuradorNome String?
  emissao        DateTime?
  validade       DateTime?
  proximaRenov   DateTime?
  cnd            Boolean   @default(false)
  statusSn       String?
  nbs            Boolean   @default(false)
  ctn            Boolean   @default(false)
  arquivoPath    String?
  cliente        Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clienteId])
  @@map("procuracoes_ecac")
}

/// Acesso DECWEB (login + senha do portal de declarações).
/// senha CRIPTOGRAFADA igual CertificadoDigital.
model AcessoDecweb {
  id                 String    @id @default(cuid())
  clienteId          String
  login              String?
  senhaCriptografada String?
  procuracao         Boolean   @default(false)
  proximaRenov       DateTime?
  observacao         String?
  cliente            Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clienteId])
  @@map("acessos_decweb")
}

/// Matriz cliente × setor × papel (V-106 RESPONSÁVEIS, 87 cols).
/// Substitui os 3 strings antigos (respFiscal/Folha/Contabil) por relação rica.
model ClienteResponsavel {
  id         String           @id @default(cuid())
  clienteId  String
  userId     String
  setor      SetorResponsavel
  papel      PapelResponsavel @default(PRINCIPAL)
  dataInicio DateTime?
  dataFim    DateTime?
  observacao String?
  cliente    Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([clienteId, setor, papel])
  @@index([userId])
  @@map("cliente_responsaveis")
}

enum SetorResponsavel {
  FISCAL
  FOLHA
  CONTABIL
  SOCIETARIO
  COMERCIAL
  FINANCEIRO
  BPO
  GESTAO_CONTRATOS
  GESTAO_AGENDAS
  GESTAO_COBRANCAS
  RECEPCAO
}

enum PapelResponsavel {
  PRINCIPAL
  SUPORTE
  REVISOR
}

/// Parceiro externo (contador, advogado, consultor) que indica clientes
/// em troca de comissão.
model Parceiro {
  id           String             @id @default(cuid())
  nome         String
  cpfCnpj      String             @unique
  percComissao Decimal?           @db.Decimal(5, 2)
  contato      String?
  email        String?
  ativo        Boolean            @default(true)
  indicacoes   Indicacao[]
  comissoes    ComissaoParceiro[]
  createdAt    DateTime           @default(now())

  @@map("parceiros")
}

/// Programa de indicação V-106 (4 abas: CLIENTE/PARCEIRO/EQUIPE INDICA + REDE IDEIA).
model Indicacao {
  id                    String          @id @default(cuid())
  origem                OrigemIndicacao
  indicadorClienteId    String?
  indicadorParceiroId   String?
  indicadorUserId       String?
  nomeAmigo             String? // indicações fora da base
  indicadoClienteId     String?
  indicadoPreCadastroId String?
  servico               String // "ABERTURA DE EMPRESA", etc.
  dataIndicacao         DateTime
  prazoUso              DateTime?
  voucherValor          Decimal?        @db.Decimal(14, 2)
  status                StatusIndicacao @default(PENDENTE)
  dataUso               DateTime?
  datasUsoExtras        Json? // ["20/09/21", "20/10/21"]
  observacao            String?         @db.Text
  indicadorCliente      Cliente?        @relation("ClienteIndicador", fields: [indicadorClienteId], references: [id], onDelete: SetNull)
  indicadorParceiro     Parceiro?       @relation(fields: [indicadorParceiroId], references: [id], onDelete: SetNull)
  indicadoCliente       Cliente?        @relation("ClienteIndicado", fields: [indicadoClienteId], references: [id], onDelete: SetNull)
  createdAt             DateTime        @default(now())

  @@index([origem, status])
  @@index([indicadorClienteId])
  @@index([indicadorParceiroId])
  @@map("indicacoes")
}

enum OrigemIndicacao {
  CLIENTE
  PARCEIRO
  REDE_IDEIA
  EQUIPE
}

enum StatusIndicacao {
  PENDENTE
  UTILIZADO
  EXPIRADO
  CANCELADO
}

/// Comissão mensal devida a parceiro pela rede REDE IDEIA.
model ComissaoParceiro {
