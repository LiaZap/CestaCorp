  formResponseId  String
  fieldKey        String
  hash            String // referência FileMetadata
  driveFileId     String?
  driveFolderPath String?
  uploadedAt      DateTime @default(now())

  @@index([formResponseId])
  @@map("form_file_uploads")
}
